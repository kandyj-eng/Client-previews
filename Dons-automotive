<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Don't Automotive | Asian & Domestic Auto Repair | Austin</title>
<meta name="description" content="Old-fashioned honesty meets state-of-the-art diagnostics. Serving Austin on South First Street since 1980."/>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;500;600;700&family=Barlow+Condensed:wght@500;700&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    /* Vintage Crimson & Retro Cream Palette */
    --accent: #CE2626; 
    --accent-dark: #A81E1E; 
    --highlight: #FFF8EC;
    --dark: #1A1615; 
    --dark2: #241E1C; 
    --dark3: #332A28;
    --light: #E8DCC8; 
    --white: #FFF8EC;
    --font-head: 'Bebas Neue', sans-serif;
    --font-body: 'Barlow', sans-serif;
    --font-sub: 'Barlow Condensed', sans-serif;
  }
  body { font-family: var(--font-body); background: var(--dark); color: var(--white); overflow-x: hidden; }

  nav {
    background: rgba(26,22,21,0.97); border-bottom: 3px solid var(--accent);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 2rem; height: 56px; position: sticky; top: 0; z-index: 100;
  }
  .nav-logo { font-family: var(--font-head); font-size: 26px; letter-spacing: 2px; color: var(--white); display: flex; align-items: center; gap: 10px; }
  .nav-logo span { color: var(--accent); }
  .nav-loc { font-family: var(--font-sub); font-size: 12px; color: #999; letter-spacing: 1px; text-transform: uppercase; padding-left: 10px; border-left: 1px solid rgba(255,248,236,0.1); }
  .nav-links { display: flex; gap: 1.75rem; }
  .nav-links a { font-family: var(--font-sub); font-size: 14px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--light); text-decoration: none; cursor: pointer; border-bottom: 2px solid transparent; padding-bottom: 2px; transition: color 0.2s; }
  .nav-links a:hover, .nav-links a.active { color: var(--accent); border-color: var(--accent); }
  .nav-cta { background: var(--accent); color: var(--white); font-family: var(--font-sub); font-weight: 700; font-size: 13px; letter-spacing: 2px; text-transform: uppercase; border: none; padding: 9px 20px; cursor: pointer; transition: background 0.2s; }
  .nav-cta:hover { background: var(--accent-dark); }

  .page { display: none; }
  .page.active { display: block; }

  .hero { position: relative; background: var(--dark); padding: 4rem 2rem 2.5rem; overflow: hidden; display: flex; justify-content: center; }
  .hero-bg-pattern { position: absolute; inset: 0; background-image: repeating-linear-gradient(45deg, transparent, transparent 40px, rgba(206,38,38,0.04) 40px, rgba(206,38,38,0.04) 41px); }
  .hero-accent { position: absolute; right: 0; top: 0; bottom: 0; width: 40%; background: var(--accent); clip-path: polygon(14% 0, 100% 0, 100% 100%, 0% 100%); opacity: 0.07; }
  .hero-content { position: relative; z-index: 2; max-width: 660px; text-align: center; }
  .hero-tag { display: inline-block; background: var(--dark2); color: var(--accent); border: 1px solid var(--accent); font-family: var(--font-sub); font-size: 12px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; padding: 4px 12px; margin-bottom: 1rem; }
  .hero h1 { font-family: var(--font-head); font-size: clamp(52px, 8vw, 88px); line-height: 0.92; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 1rem; color: var(--highlight); }
  .hero h1 em { color: var(--accent); font-style: normal; }
  .hero-sub { font-size: 16px; color: #C0B5A6; max-width: 480px; line-height: 1.6; margin-bottom: 1.75rem; margin-left: auto; margin-right: auto; }
  .hero-sub strong { color: var(--white); }
  .hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; margin-bottom: 2rem; }
  .btn-primary { background: var(--accent); color: var(--white); font-family: var(--font-sub); font-weight: 700; font-size: 14px; letter-spacing: 2px; text-transform: uppercase; border: none; padding: 14px 30px; cursor: pointer; transition: background 0.2s, transform 0.15s; }
  .btn-primary:hover { background: var(--accent-dark); transform: translateY(-2px); }
  .btn-outline { background: transparent; color: var(--white); font-family: var(--font-sub); font-weight: 700; font-size: 14px; letter-spacing: 2px; text-transform: uppercase; border: 2px solid #665A56; padding: 12px 28px; cursor: pointer; transition: border-color 0.2s, color 0.2s; }
  .btn-outline:hover { border-color: var(--accent); color: var(--accent); }
  .hero-stats { display: flex; gap: 2.5rem; justify-content: center; padding-top: 1.5rem; border-top: 1px solid rgba(255,248,236,0.1); }
  .hero-stat-num { font-family: var(--font-head); font-size: 38px; color: var(--accent); line-height: 1; }
  .hero-stat-label { font-family: var(--font-sub); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; color: #A89D8F; margin-top: 3px; }

  .marquee-strip { background: var(--accent); padding: 12px 0; overflow: hidden; white-space: nowrap; margin-top: 2rem; }
  .marquee-inner { display: inline-flex; animation: marquee 22s linear infinite; }
  .marquee-item { font-family: var(--font-head); font-size: 20px; letter-spacing: 3px; text-transform: uppercase; padding: 0 1.75rem; color: var(--highlight); }
  .marquee-dot { color: var(--dark); opacity: 0.5; }
  @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  .section { padding: 3.5rem 2rem; }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-label { font-family: var(--font-sub); font-size: 12px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--accent); margin-bottom: 0.4rem; }
  .section-title { font-family: var(--font-head); font-size: clamp(32px, 5vw, 50px); letter-spacing: 1px; text-transform: uppercase; line-height: 1; margin-bottom: 1.25rem; color: var(--highlight); }

  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5px; background: rgba(255,248,236,0.05); border: 1.5px solid rgba(255,248,236,0.05); margin-top: 2rem; }
  @media (max-width: 768px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  .service-card { background: var(--dark2); padding: 1.75rem 1.5rem; transition: background 0.2s; position: relative; overflow: hidden; }
  .service-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--accent); transform: scaleX(0); transform-origin: left; transition: transform 0.3s; }
  .service-card:hover::before { transform: scaleX(1); }
  .service-card:hover { background: var(--dark3); }
  .service-icon { font-size: 28px; margin-bottom: 0.75rem; }
  .service-name { font-family: var(--font-sub); font-size: 16px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 0.4rem; color: var(--highlight); }
  .service-desc { font-size: 13px; color: #C0B5A6; line-height: 1.5; }

  .why-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 1.25rem; margin-top: 2rem; }
  .why-card { background: var(--dark2); border: 1.5px solid rgba(255,248,236,0.1); padding: 1.5rem; }
  .why-num { font-family: var(--font-head); font-size: 44px; color: var(--accent); line-height: 1; margin-bottom: 0.25rem; }
  .why-label { font-family: var(--font-sub); font-size: 14px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--highlight); margin-bottom: 0.4rem; }
  .why-desc { font-size: 13px; color: #A89D8F; line-height: 1.5; }

  .services-page-hero { background: var(--dark2); border-bottom: 3px solid var(--accent); padding: 3rem 2rem 2.5rem; text-align: center; }
  .services-big-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.75rem; margin-top: 2.5rem; text-align: left;}
  .service-big-card { background: var(--dark2); border: 1.5px solid rgba(255,248,236,0.1); padding: 1.75rem; transition: border-color 0.2s, transform 0.2s; position: relative; }
  .service-big-card:hover { border-color: var(--accent); transform: translateY(-4px); }
  .service-price { font-family: var(--font-head); font-size: 32px; color: var(--accent); margin-bottom: 0.2rem; letter-spacing: 1px;}
  .service-price-label { font-size: 12px; color: #A89D8F; margin-bottom: 1rem; }
  .service-features { list-style: none; margin: 1rem 0; }
  .service-features li { font-size: 13px; color: #C0B5A6; padding: 6px 0; border-bottom: 1px solid rgba(255,248,236,0.05); display: flex; align-items: center; gap: 8px; }
  .service-features li::before { content: '✓'; color: var(--accent); font-weight: 700; font-size: 12px; }
  
  .about-split { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; margin-top: 2.5rem; text-align: left; }
  @media (max-width: 680px) { .about-split, .contact-grid { grid-template-columns: 1fr; } }
  .about-img-mock { background: var(--dark2); border: 1.5px solid rgba(255,248,236,0.1); aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; font-size: 70px; position: relative; overflow: hidden; }
  .about-img-mock::after { content: 'EST. 1980 · SOUTH FIRST ST'; position: absolute; bottom: 1rem; right: 1rem; font-family: var(--font-head); font-size: 14px; letter-spacing: 2px; color: var(--accent); }
  .about-text p { font-size: 15px; color: #C0B5A6; line-height: 1.75; margin-bottom: 0.9rem; }
  .about-text strong { color: var(--highlight); }

  .contact-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 3.5rem; margin-top: 2.5rem; align-items: start; text-align: left;}
  .contact-info-block { margin-bottom: 1.75rem; }
  .contact-info-label { font-family: var(--font-sub); font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--accent); margin-bottom: 0.4rem; }
  .contact-info-val { font-size: 15px; color: var(--highlight); line-height: 1.6; }
  
  .form-group { margin-bottom: 1rem; }
  .form-label { display: block; font-family: var(--font-sub); font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #A89D8F; margin-bottom: 5px; }
  .form-input, .form-select, .form-textarea { width: 100%; background: var(--dark2); border: 1.5px solid rgba(255,248,236,0.1); color: var(--white); font-family: var(--font-body); font-size: 14px; padding: 11px 13px; outline: none; transition: border-color 0.2s; appearance: none; }
  .form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--accent); }
  .form-textarea { resize: vertical; min-height: 100px; }
  .form-select option { background: var(--dark2); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .submit-confirm { background: var(--dark2); border: 1.5px solid #2C2; color: #6F6; padding: 0.9rem 1.25rem; font-family: var(--font-sub); font-size: 14px; letter-spacing: 1px; margin-top: 0.75rem; display: none; }

  footer { background: #141110; border-top: 3px solid var(--accent); padding: 2rem; text-align: center; }
  .footer-logo { font-family: var(--font-head); font-size: 28px; letter-spacing: 3px; margin-bottom: 0.25rem; }
  .footer-logo span { color: var(--accent); }
  .footer-address { font-size: 13px; color: #A89D8F; margin-bottom: 0.3rem; }
  .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }
</style>
</head>
<body>

<h2 class="sr-only">Don's Automotive — Old-fashioned honesty meets state-of-the-art diagnostics. Asian and Domestic auto repair in Austin since 1980.</h2>

<nav>
  <div class="nav-logo">DON'S<span>AUTOMOTIVE</span> <span class="nav-loc">South First St, Austin</span></div>
  <div class="nav-links">
    <a onclick="showPage('home')" class="active" id="nav-home">Home</a>
    <a onclick="showPage('services')" id="nav-services">Diagnostics</a>
    <a onclick="showPage('about')" id="nav-about">The Journal</a>
    <a onclick="showPage('contact')" id="nav-contact">Contact</a>
  </div>
  <button class="nav-cta" onclick="showPage('contact')">Call Us</button>
</nav>

<div class="page active" id="page-home">

  <section class="hero">
    <div class="hero-bg-pattern"></div>
    <div class="hero-accent"></div>
    <div class="hero-content">
      <div class="hero-tag">&#9881; Est. 1980 &middot; Austin, TX</div>
      <h1>Old-Fashioned <em>Honesty</em>.<br>State-of-the-Art <em>Diagnostics</em>.</h1>
      <p class="hero-sub"><strong>We answer the phone. We fix the car.</strong><br><br>Serving Austin since 1980 with fiercely independent, highly technical Asian and Domestic auto repair. We combine old-school integrity with modern, specialized equipment.</p>
      <div class="hero-btns">
        <button class="btn-primary" onclick="showPage('contact')">Contact the Shop</button>
        <button class="btn-outline" onclick="showPage('services')">View Capabilities</button>
      </div>
      <div class="hero-stats">
        <div><div class="hero-stat-num">1980</div><div class="hero-stat-label">Year Founded</div></div>
        <div><div class="hero-stat-num">$3.5k</div><div class="hero-stat-label">Scanner Tech</div></div>
        <div><div class="hero-stat-num">100%</div><div class="hero-stat-label">Independent</div></div>
      </div>
    </div>
  </section>

  <div class="marquee-strip">
    <div class="marquee-inner">
      <span class="marquee-item">Advanced Diagnostics <span class="marquee-dot">&#10022;</span></span>
      <span class="marquee-item">Hybrid AC Specialists <span class="marquee-dot">&#10022;</span></span>
      <span class="marquee-item">Smoke Machine Testing <span class="marquee-dot">&#10022;</span></span>
      <span class="marquee-item">Asian &amp; Domestic <span class="marquee-dot">&#10022;</span></span>
      <span class="marquee-item">Honest Work <span class="marquee-dot">&#10022;</span></span>
      <span class="marquee-item">Advanced Diagnostics <span class="marquee-dot">&#10022;</span></span>
      <span class="marquee-item">Hybrid AC Specialists <span class="marquee-dot">&#10022;</span></span>
      <span class="marquee-item">Smoke Machine Testing <span class="marquee-dot">&#10022;</span></span>
      <span class="marquee-item">Asian &amp; Domestic <span class="marquee-dot">&#10022;</span></span>
      <span class="marquee-item">Honest Work <span class="marquee-dot">&#10022;</span></span>
    </div>
  </div>

  <section class="section" style="text-align: center;">
    <div class="section-inner">
      <div class="section-label" style="display: flex; justify-content: center;">Technical Capabilities</div>
      <div class="section-title">Specialized Auto Repair</div>
      <p style="color:#C0B5A6; max-width:520px; font-size:15px; margin-left: auto; margin-right: auto;">Don't let the vintage vibe fool you. We invest heavily in the specialized tools and machines required to service modern engines properly.</p>
      <div class="services-grid" style="text-align: left;">
        <div class="service-card"><div class="service-icon">&#128187;</div><div class="service-name">Computerized Diagnostics</div><div class="service-desc">We utilize premium $3,500 diagnostic scanners to communicate directly with your vehicle's complex computer systems.</div></div>
        <div class="service-card"><div class="service-icon">&#9889;</div><div class="service-name">Hybrid & Prius AC</div><div class="service-desc">We operate dedicated AC machines specifically formulated for Toyota Prius and Honda hybrid power systems.</div></div>
        <div class="service-card"><div class="service-icon">&#128295;</div><div class="service-name">Smoke Machine Leaks</div><div class="service-desc">We use advanced smoke machine leak detectors to find hidden vacuum, exhaust, and EVAP system leaks.</div></div>
      </div>
    </div>
  </section>

</div>

<div class="page" id="page-services">
  <div class="services-page-hero">
    <div class="section-label">Service &amp; Labor Rates</div>
    <div class="section-title" style="font-size: clamp(36px,6vw,64px);">Premium Tech.<br>No Guesswork.</div>
    <p style="color:#C0B5A6; max-width:500px; margin: 0.6rem auto 0; font-size:15px;">We diagnose the real issue using state-of-the-art equipment, saving you money on parts-cannon guesswork.</p>
  </div>
  <section class="section">
    <div class="section-inner">
      <div class="services-big-grid">
        <div class="service-big-card" style="border-color: var(--accent);">
          <div class="service-tag-pop">Highly Technical</div>
          <div class="service-name" style="font-size:18px; margin-bottom: 0.2rem;">Expert Labor Rate</div>
          <div class="service-price">$190<span style="font-size:16px; color:#A89D8F;">/hr</span></div>
          <p style="color:#C0B5A6; font-size:14px; margin-top: 10px; margin-bottom: 15px;">We proudly charge a premium labor rate because our highly trained technicians fix it right the first time.</p>
          <ul class="service-features"><li>ASE-level mechanical expertise</li><li>Deep diagnostic analysis</li><li>Specialized import tools</li></ul>
        </div>
        <div class="service-big-card">
          <div class="service-name" style="font-size:18px; margin-bottom: 0.2rem;">Hybrid System Care</div>
          <p style="color:#C0B5A6; font-size:14px; margin-top: 10px; margin-bottom: 15px;">Asian imports and modern hybrids require specialized machines that many shops do not own. We do.</p>
          <ul class="service-features"><li>Toyota Prius specialists</li><li>Honda Hybrid AC service</li><li>High-voltage system safety</li></ul>
        </div>
      </div>
    </div>
  </section>
</div>

<div class="page" id="page-about">
  <section class="section">
    <div class="section-inner" style="text-align: center;">
      <div class="section-label" style="display: flex; justify-content: center;">Our Legacy &middot; Austin, TX</div>
      <div class="section-title">The Shop Journal</div>
      <div class="about-split">
        <div class="about-img-mock">&#128214;</div>
        <div class="about-text">
          <p>Founded in 1980, <strong>Don's Automotive</strong> is operated by Donald Lewis. For over forty years, we have provided Austin with an old-school, fiercely independent alternative to dealership repair centers.</p>
          <p>We believe in sharing automotive knowledge. As part of our shop journal, we frequently debunk <strong>"Auto Urban Legends"</strong>—like the myth that you can't store a battery on cement, or that pouring Coca-Cola on your battery terminals is a good long-term cleaning strategy.</p>
          <p>We are highly technical, proudly inclusive, and deeply involved in the Austin community. We believe in doing the job right, respecting our customers, and answering the phone when it rings.</p>
        </div>
      </div>
    </div>
  </section>
</div>

<div class="page" id="page-contact">
  <section class="section">
    <div class="section-inner" style="text-align: center;">
      <div class="section-label" style="display: flex; justify-content: center;">Talk To A Mechanic</div>
      <div class="section-title">Call Us Directly</div>
      <p style="color:#C0B5A6; font-size:15px; max-width:600px; margin: 0 auto 2.5rem auto;">We firmly believe that a quick phone call is the absolute best way to discuss your vehicle. If you cannot call right now, please use the form below.</p>
      
      <div class="contact-grid">
        <div>
          <div class="contact-info-block" style="background: rgba(206,38,38,0.1); border: 1px solid var(--accent); padding: 1.5rem; margin-bottom: 2rem;">
            <div class="contact-info-label" style="font-size:14px; color:var(--highlight); margin-bottom: 10px;">Direct Phone Line</div>
            <div class="contact-info-val" style="font-size:32px; font-family:var(--font-head); color:var(--accent);">512-447-9032</div>
            <div style="font-size:12px; color:#A89D8F; margin-top:5px; text-transform:uppercase; letter-spacing:1px;">Call us! Email takes longer.</div>
          </div>
          
          <div class="contact-info-block">
            <div class="contact-info-label">Address</div>
            <div class="contact-info-val">South First Street<br>Austin, TX</div>
          </div>
        </div>
        <div>
          <div class="form-row">
            <div class="form-group"><label class="form-label">First Name</label><input class="form-input" type="text" placeholder="Your Name" id="fname"/></div>
            <div class="form-group"><label class="form-label">Phone Number</label><input class="form-input" type="tel" placeholder="(512) 555-0000" id="phone"/></div>
          </div>
          <div class="form-group"><label class="form-label">Vehicle (Make/Model/Year)</label><input class="form-input" type="text" placeholder="e.g. 2017 Toyota Prius" id="vehicle"/></div>
          
          <div class="form-group">
            <label class="form-label">Why are you reaching out?</label>
            <select class="form-select" id="service">
              <option value="">— Select a reason —</option>
              <option>Check Engine Light / Diagnostics</option><option>Hybrid AC / Battery Service</option>
              <option>Asian/Domestic Repair</option><option>Other</option>
            </select>
          </div>
          <div class="form-group"><label class="form-label">Details</label><textarea class="form-textarea" placeholder="Briefly describe the issue..." id="notes"></textarea></div>
          <button class="btn-primary" style="width:100%; font-size:15px; padding:16px;" onclick="submitForm()">Send Message &rarr;</button>
          <div class="submit-confirm" id="form-confirm">&#10003; Message received! We will follow up with you as soon as we put the wrenches down.</div>
        </div>
      </div>
    </div>
  </section>
</div>

<footer>
  <div class="footer-logo">DON'S<span>AUTOMOTIVE</span></div>
  <div class="footer-address">South First Street &middot; Austin, TX &middot; 512-447-9032</div>
  <div class="footer-areas" style="color: #665A56; font-size: 11px; margin-top: 10px;">Est. 1980. Independent Asian & Domestic Auto Repair.</div>
</footer>

<script>
  function showPage(name) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
    document.getElementById('page-' + name).classList.add('active');
    document.getElementById('nav-' + name).classList.add('active');
    window.scrollTo(0, 0);
  }
  function submitForm() {
    const fname = document.getElementById('fname').value.trim();
    const service = document.getElementById('service').value;
    if (!fname || !service) { alert('Please fill in your name and select a reason.'); return; }
    const confirm = document.getElementById('form-confirm');
    confirm.style.display = 'block';
    confirm.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
</script>
</body>
</html>
